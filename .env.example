# GEMINI_API_KEY="your_gemini_api_key_here"
# GEMINI_MODEL=gemini-3.5-flash
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="llama3"
# OLLAMA_API_KEY=""
QWEN_API_KEY="your_qwen_api_key_here"
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_MODEL="qwen-plus"
# SQLite (default)
# DATABASE_URL=sqlite:///./salon_ai.db

# MySQL example (SQLAlchemy + PyMySQL)
DATABASE_URL=mysql+pymysql://your_mysql_user:your_mysql_password_here@localhost:3306/salon_ai

# Optional MySQL pool tuning
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# Optional SMS notifications (Twilio)
TWILIO_ACCOUNT_SID="your_twilio_account_sid_here"
TWILIO_AUTH_TOKEN="your_twilio_auth_token_here"
TWILIO_FROM_NUMBER=+12345678901

